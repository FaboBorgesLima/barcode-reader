<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ═══════════════════════════════════════ -->
    <!--         SCANNER CORNER BRACKETS        -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Top-left bracket -->
    <path android:fillColor="#00E5FF"
        android:pathData="M20,20 h17 v4 h-17 z
                          M20,20 h4 v17 h-4 z" />

    <!-- Top-right bracket -->
    <path android:fillColor="#00E5FF"
        android:pathData="M71,20 h17 v4 h-17 z
                          M84,20 h4 v17 h-4 z" />

    <!-- Bottom-left bracket -->
    <path android:fillColor="#00E5FF"
        android:pathData="M20,84 h17 v4 h-17 z
                          M20,71 h4 v17 h-4 z" />

    <!-- Bottom-right bracket -->
    <path android:fillColor="#00E5FF"
        android:pathData="M71,84 h17 v4 h-17 z
                          M84,71 h4 v17 h-4 z" />

    <!-- Small corner dots (accent) -->
    <path android:fillColor="#80FFFFFF"
        android:pathData="M18,18 h4 v4 h-4 z
                          M86,18 h4 v4 h-4 z
                          M18,86 h4 v4 h-4 z
                          M86,86 h4 v4 h-4 z" />

    <!-- ═══════════════════════════════════════ -->
    <!--           BARCODE BARS                 -->
    <!-- ═══════════════════════════════════════ -->
    <!-- Bars run from y=35 to y=73 (height=38) -->
    <path android:fillColor="#BFFFFFFF"
        android:pathData="
            M28,35 h2 v38 h-2 z
            M32,35 h1 v38 h-1 z
            M35,35 h3 v38 h-3 z
            M40,35 h2 v38 h-2 z
            M44,35 h1 v38 h-1 z
            M47,35 h3 v38 h-3 z
            M52,35 h2 v38 h-2 z
            M56,35 h1 v38 h-1 z
            M59,35 h3 v38 h-3 z
            M64,35 h2 v38 h-2 z
            M68,35 h1 v38 h-1 z
            M71,35 h3 v38 h-3 z
            M76,35 h1 v38 h-1 z
            M79,35 h2 v38 h-2 z" />

    <!-- ═══════════════════════════════════════ -->
    <!--         GLOWING SCAN LINE              -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Outer soft glow (wide band) -->
    <path android:pathData="M20,47 h68 v14 h-68 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="20" android:startY="54"
                android:endX="88"   android:endY="54"
                android:type="linear">
                <item android:offset="0.0" android:color="#0000FF80" />
                <item android:offset="0.25" android:color="#2200FF80" />
                <item android:offset="0.5"  android:color="#3300FF88" />
                <item android:offset="0.75" android:color="#2200FF80" />
                <item android:offset="1.0" android:color="#0000FF80" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner glow (medium band) -->
    <path android:pathData="M20,50 h68 v8 h-68 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="20" android:startY="54"
                android:endX="88"   android:endY="54"
                android:type="linear">
                <item android:offset="0.0" android:color="#0000FF88" />
                <item android:offset="0.2" android:color="#4400FF8A" />
                <item android:offset="0.5"  android:color="#7700FF8A" />
                <item android:offset="0.8" android:color="#4400FF8A" />
                <item android:offset="1.0" android:color="#0000FF88" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Core bright scan line -->
    <path android:pathData="M20,52 h68 v4 h-68 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="20" android:startY="54"
                android:endX="88"   android:endY="54"
                android:type="linear">
                <item android:offset="0.0"  android:color="#0000FF88" />
                <item android:offset="0.15" android:color="#BB00FF88" />
                <item android:offset="0.5"  android:color="#FF00FFB0" />
                <item android:offset="0.85" android:color="#BB00FF88" />
                <item android:offset="1.0"  android:color="#0000FF88" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Scan line edge chevrons (indicate direction) -->
    <path android:fillColor="#CC00FFB0"
        android:pathData="M20,52 l-3,-3 l0,10 l3,-3 z
                          M88,52 l3,-3 l0,10 l-3,-3 z" />

</vector>